# Copy to .env and set a strong random value for production.
UPLOAD_SECRET=change-me-to-a-long-random-secret

# Optional display name for the UI header and sidebar.
# PROJECT_NAME=My App

# Optional: SQLite database URL (default: sqlite:///./releases.db)
# DATABASE_URL=sqlite:///./releases.db

# Optional: path to an SVG file shown as the logo (served at /logo.svg)
# LOGO_SVG_PATH=/absolute/path/to/logo.svg
